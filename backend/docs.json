        "tags": [
          "Registros"
        ],
        "summary": "Get last registro of a rut",
        "description": "Get last registro of a rut",
        "operationId": "get_last",
        "parameters": [
          {
            "name": "rut",
            "in": "path",
            "description": "Rut of the user",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "123456789"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RegistroModel"
                  }
                },
                "examples": {

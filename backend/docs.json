  "components": {
    "schemas": {
      "LoginAdmin": {
        "type": "object",
        "required": [
          "email",
          "pswd"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "pswd": {
            "type": "string"
          }
        }
      },
      "RegistroAlumno": {
        "type": "object",
        "required": [
          "id",
          "nombre",
          "apellido_1",
          "apellido_2",
          "rut",
          "correo_uai",
          "fecha",
          "salida",
          "rol",
          "motivo"
        ],
        "properties": {
          "apellido_1": {
            "type": "string"
          },
          "apellido_2": {
            "type": "string"
          },
          "correo_uai": {
            "type": "string"
          },
          "fecha": {
            "type": "string",
            "format": "date-time"
          },
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "motivo": {
            "type": "string"
          },
          "nombre": {
            "type": "string"
          },
          "rol": {
            "type": "string"
          },
          "rut": {
            "type": "string"
          },
          "salida": {
            "type": "boolean"
          }
        }
      },
      "RegistroModel": {
        "type": "object",
        "required": [
          "id",
          "rut",
          "fecha",
          "salida",
          "motivo"
        ],
        "properties": {
          "fecha": {
            "type": "string",
            "format": "date-time"
          },
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "motivo": {
            "type": "string"
          },
          "rut": {
            "type": "string"
          },
          "salida": {
            "type": "boolean"
          }
        }
      },
      "RegistroNew": {
        "type": "object",
        "required": [
          "rut",
          "salida",
          "motivo"
        ],
        "properties": {
          "motivo": {
            "type": "string"
          },
          "rut": {
            "type": "string"
          },
          "salida": {
            "type": "boolean"
          }
        }
      },
      "RequestAdmin": {
        "type": "object",
        "required": [
          "nombre",
          "apellido_1",
          "apellido_2",
          "email",
          "pswd"
        ],
        "properties": {
          "apellido_1": {
            "type": "string"
          },
          "apellido_2": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "nombre": {
            "type": "string"
          },
          "pswd": {
            "type": "string"
          }
        }
      },
      "ResponseAdmin": {
        "type": "object",
        "required": [
          "nombre",
          "apellido_1",
          "apellido_2",
          "email"
        ],
        "properties": {
          "apellido_1": {
            "type": "string",
            "example": "Banner"
          },
          "apellido_2": {
            "type": "string",
            "example": "The Hulk"
          },
          "cookie": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "example": "bbanner@alumnos.uai.cl"
          },
          "nombre": {
            "type": "string",
            "example": "Bruce"
          }
        }
      },
      "UserModel": {
        "type": "object",
        "required": [
          "nombre",
          "apellido_1",
          "apellido_2",
          "rut",
          "print_path",
          "correo_uai",
          "is_disabled",
          "rol"
        ],
        "properties": {
          "apellido_1": {
            "type": "string"
          },
          "apellido_2": {
            "type": "string"
          },
          "correo_uai": {
            "type": "string"
          },
          "is_disabled": {
            "type": "boolean"
          },
          "nombre": {
            "type": "string"
          },
          "print_path": {
            "type": "string"
          },
          "rol": {
            "type": "string"
          },
          "rut": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "auth-cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "auth-cookie"
      }
    }
  },
  "tags": [
